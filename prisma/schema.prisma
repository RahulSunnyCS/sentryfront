// VibeSafe database schema
//
// Auto-switches between SQLite (dev) and PostgreSQL (prod) based on NODE_ENV
// - development: Uses DEV_DATABASE_URL (SQLite)
// - production: Uses DATABASE_URL (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  tier             String    @default("free")
  stripeCustomerId String?
  createdAt        DateTime  @default(now())

  // Weekly passive-scan quota (free tier = 1/week)
  scansThisWeek Int       @default(0)
  scanWeekStart DateTime?

  // Active DAST credits granted via Verify ($9) / Active Pack ($29)
  activeTestCredits Int @default(0)

  accounts            Account[]
  sessions            Session[]
  scans               Scan[]
  domainVerifications DomainVerification[]
}

// ── NextAuth Tables ──────────────────────────────────────────────────────────
// Required by NextAuth.js for OAuth authentication
// See: https://authjs.dev/reference/adapter/prisma

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Scan {
  id          String    @id @default(cuid())
  userId      String?
  targetUrl   String
  status      String    @default("QUEUED")
  tier        String    @default("free")
  grade       String? // Security grade (A-F)
  score       Float? // Security score (0-100)
  stack       String?
  summary     String? // JSON string — e.g. {"CRITICAL":2,"HIGH":4,...}
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  requesterIp String?

  // Phase 5.5: Performance scanning results
  performanceGrade   String? // Performance grade (A-F)
  performanceScore   Float? // Performance score (0-100)
  performanceMetrics String? // JSON string — e.g. {"lcp":2400,"cls":0.05,...}

  // Phase 6.5: Accessibility scanning results
  accessibilityGrade   String? // Accessibility grade (A-F)
  accessibilityScore   Float? // Accessibility score (0-100)
  accessibilityMetrics String? // JSON string — e.g. {"violations":[...]}

  // Phase 7.5: SEO scanning results
  seoGrade   String? // SEO grade (A-F)
  seoScore   Float? // SEO score (0-100)
  seoMetrics String? // JSON string — e.g. {"issues":[...]}

  user     User?       @relation(fields: [userId], references: [id])
  findings Finding[]
  events   ScanEvent[]
}

model Finding {
  id          String @id @default(cuid())
  scanId      String
  moduleId    String
  severity    String
  category    String
  title       String
  location    String
  evidence    String
  explanation String
  impact      String
  fixManual   String // JSON array of strings
  fixAiPrompt String

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

// Lightweight event log — used as SSE fallback when Redis is absent.
model ScanEvent {
  id        Int      @id @default(autoincrement())
  scanId    String
  eventType String
  payload   String // JSON string
  createdAt DateTime @default(now())

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
}

model DomainVerification {
  id         String    @id @default(cuid())
  userId     String
  domain     String
  method     String    @default("dns_txt")
  token      String
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
