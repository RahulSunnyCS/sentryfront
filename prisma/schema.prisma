// VibeSafe database schema
//
// Auto-switches between SQLite (dev) and PostgreSQL (prod) based on NODE_ENV
// - development: Uses DEV_DATABASE_URL (SQLite)
// - production: Uses DATABASE_URL (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DEV_DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  tier             String    @default("free")
  stripeCustomerId String?
  createdAt        DateTime  @default(now())

  // Weekly passive-scan quota (free tier = 1/week)
  scansThisWeek Int       @default(0)
  scanWeekStart DateTime?

  // Active DAST credits granted via Verify ($9) / Active Pack ($29)
  activeTestCredits Int @default(0)

  accounts            Account[]
  sessions            Session[]
  scans               Scan[]
  domainVerifications DomainVerification[]
  dispositions        FindingDisposition[]
}

// ── NextAuth Tables ──────────────────────────────────────────────────────────
// Required by NextAuth.js for OAuth authentication
// See: https://authjs.dev/reference/adapter/prisma

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Scan {
  id          String    @id @default(cuid())
  userId      String?
  targetUrl   String
  inputType   String    @default("url") // "url" | "apk" | "ipa"
  targetLabel String?                   // human-readable: domain or app filename
  status      String    @default("QUEUED")
  tier        String    @default("free")
  grade       String? // Security grade (A-F)
  score       Float? // Security score (0-100)
  stack       String?
  summary     String? // JSON string — e.g. {"CRITICAL":2,"HIGH":4,...}
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  requesterIp String?

  // Phase 5.5: Performance scanning results
  performanceGrade   String? // Performance grade (A-F)
  performanceScore   Float? // Performance score (0-100)
  performanceMetrics String? // JSON string — e.g. {"lcp":2400,"cls":0.05,...}

  // Phase 6.5: Accessibility scanning results
  accessibilityGrade   String? // Accessibility grade (A-F)
  accessibilityScore   Float? // Accessibility score (0-100)
  accessibilityMetrics String? // JSON string — e.g. {"violations":[...]}

  // Phase 7.5: SEO scanning results
  seoGrade   String? // SEO grade (A-F)
  seoScore   Float? // SEO score (0-100)
  seoMetrics String? // JSON string — e.g. {"issues":[...]}

  user         User?                @relation(fields: [userId], references: [id])
  findings     Finding[]
  events       ScanEvent[]
  dispositions FindingDisposition[]

  @@index([userId, startedAt, id])
  @@index([userId, grade])
}

model Finding {
  id          String  @id @default(cuid())
  scanId      String
  moduleId    String
  severity    String
  category    String
  title       String
  location    String
  evidence    String
  explanation String
  impact      String
  fixManual   String // JSON array of strings
  fixAiPrompt String
  // Phase 3.7 — emission confidence for FP-rate bucketing.
  // Populated by 3.11's tunable modules; null on legacy modules.
  confidence  String?

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

// Phase 3.7 — append-only user verdicts on findings.
// Multiple rows per (scanId, findingId, userId) allowed; aggregation
// takes the most-recent row per triple. No @@unique on purpose so we
// can audit changes of mind.
//
// Disposition values: 'helpful' | 'dismissed' | 'fp' | 'fix_didnt_help'
// plus 'missed_other' reserved for the recall-side substep (3.7.1)
// — schema accepts it now so no migration is needed when the UI lands.
model FindingDisposition {
  id          String   @id @default(cuid())
  scanId      String
  findingId   String
  userId      String
  disposition String
  createdAt   DateTime @default(now())

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([scanId, findingId, userId])
  @@index([findingId])
  @@index([createdAt])
}

// Lightweight event log — used as SSE fallback when Redis is absent.
model ScanEvent {
  id        Int      @id @default(autoincrement())
  scanId    String
  eventType String
  payload   String // JSON string
  createdAt DateTime @default(now())

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
}

model DomainVerification {
  id         String    @id @default(cuid())
  userId     String
  domain     String
  method     String    @default("dns_txt")
  token      String
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Phase 3.7.1 — runtime feature-flag overrides. Layer on top of env-driven
// defaults in src/lib/features.ts; the helper in src/lib/feature-flags.ts
// reads through a 30s cache. value stores JSON as String for cross-db parity
// with sqlite (dev) — same pattern as Scan.summary / ScanEvent.payload.
model FeatureFlag {
  key       String   @id
  enabled   Boolean  @default(false)
  value     String?
  updatedBy String?
  updatedAt DateTime @updatedAt
}

// Append-only audit log for every FeatureFlag flip. Also reused with
// synthetic keys like "quota:<userId>" for admin quota overrides so we
// don't have to maintain two audit tables.
model FeatureFlagAudit {
  id        String   @id @default(cuid())
  key       String
  enabled   Boolean
  value     String?
  updatedBy String?
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

// Phase 3.7.1 — daily snapshot of aggregated FP rates per (moduleId, confidence).
// Written by the existing aggregate-fp-rates cron and consumed by the
// /internal/fp-rates admin page so sparklines don't require a full scan
// of FindingDisposition on every page view.
model FpRateSnapshot {
  id                String   @id @default(cuid())
  snapshotAt        DateTime @default(now())
  moduleId          String
  confidence        String?
  total             Int
  fpCount           Int
  helpfulCount      Int
  dismissedCount    Int
  fixDidntHelpCount Int
  missedOtherCount  Int
  fpRate            Float
  helpfulRate       Float

  @@index([moduleId, confidence, snapshotAt])
  @@index([snapshotAt])
}
