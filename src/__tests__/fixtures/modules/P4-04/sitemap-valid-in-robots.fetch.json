      "urlMatches": "/sitemap\\.xml$",
      "status": 200,
      "body": "<?xml version=\"1.0\" encoding=\"UTF-8\"?><urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\"><url><loc>https://example.com/</loc></url></urlset>"
    },
    {
      "urlMatches": "/robots\\.txt$",
