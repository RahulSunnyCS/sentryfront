{
  "manifest_version": 3,
  "name": "VibeSafe",
  "version": "0.1.0",
  "description": "Passive security & quality scan for any page you visit — including pages behind authentication.",
  "permissions": [
    "activeTab",
    "scripting",
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "VibeSafe — Scan this page"
  },
  "options_page": "options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
