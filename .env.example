# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (required):
# Neon URLs typically start with postgresql:// and include sslmode=require.
DATABASE_URL="postgresql://user:password@localhost:5432/vibesafe?schema=public"

# ── Queue (optional) ──────────────────────────────────────────────────────────
# If unset, scan jobs run as a fire-and-forget Promise in the same process.
# This is fine for local dev. For production on Vercel, set this to run
# the worker on a separate Railway/Fly.io service.
# REDIS_URL="redis://localhost:6379"

# ── LLM Enrichment (Phase 5, optional) ───────────────────────────────────────
# Scans work without LLM enrichment. If missing/invalid, deterministic findings
# are used. Set LLM_ENRICHMENT_ENABLED=false to disable even when key is present.
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-sonnet-4-20250514"
# LLM_ENRICHMENT_ENABLED="true"
# LLM_ENRICHMENT_TIMEOUT_MS="20000"

# ── Phase 6 Feature Flags (all optional, default: false) ─────────────────────
# Scan diff comparison (Pro tier feature)
# FEATURE_SCAN_DIFF_ENABLED="false"
# NEXT_PUBLIC_SCAN_DIFF_ENABLED="false"

# PDF export (direct download - no cloud storage needed!)
# Enable to allow Pro/Studio tier users to download PDF reports
# PDF_EXPORT_ENABLED="true"
# NEXT_PUBLIC_PDF_EXPORT_ENABLED="true"

# Stripe payments and subscriptions
# STRIPE_ENABLED="false"
# NEXT_PUBLIC_STRIPE_ENABLED="false"
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_PRICE_ID_ONE_SHOT="price_xxxxxxxxxxxxx"
# STRIPE_PRICE_ID_PRO_MONTHLY="price_xxxxxxxxxxxxx"
# STRIPE_PRICE_ID_STUDIO_MONTHLY="price_xxxxxxxxxxxxx"

# Authentication (Supabase or NextAuth)
# AUTH_ENABLED="false"
# NEXT_PUBLIC_AUTH_ENABLED="false"
# AUTH_PROVIDER="supabase"
# NEXT_PUBLIC_AUTH_PROVIDER="supabase"
# For Supabase:
# SUPABASE_URL=""
# NEXT_PUBLIC_SUPABASE_URL=""
# SUPABASE_ANON_KEY=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""
# For NextAuth:
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET=""
# GITHUB_ID=""
# GITHUB_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Tier-based feature gating
TIER_GATING_ENABLED="true"
NEXT_PUBLIC_TIER_GATING_ENABLED="true"

# Rate limiting
# RATE_LIMIT_PER_HOUR="10"

# ── Phase 8: Monitoring & Observability ───────────────────────────────────────
# Sentry error tracking (optional)
# SENTRY_ENABLED="false"
# SENTRY_DSN="https://xxxxxxxxxxxxx@xxxxx.ingest.sentry.io/xxxxx"
# NEXT_PUBLIC_SENTRY_ENABLED="false"
# NEXT_PUBLIC_SENTRY_DSN="https://xxxxxxxxxxxxx@xxxxx.ingest.sentry.io/xxxxx"
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="vibesafe"

# Scan timeout (milliseconds, default: 120000 = 120 seconds)
# SCAN_TIMEOUT_MS="120000"

# ── Frontend API ──────────────────────────────────────────────────────────────
# No longer needed — API routes live at the same origin (/api/v1/...).
# NEXT_PUBLIC_API_URL is deprecated.
