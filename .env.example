# ══════════════════════════════════════════════════════════════════════════════
# VibeSafe Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment ───────────────────────────────────────────────────────────────
# Controls which database to use (auto-configured by npm scripts)
# - "development" = SQLite (DEV_DATABASE_URL)
# - "production" = PostgreSQL (DATABASE_URL)
NODE_ENV="development"

# ── Database ──────────────────────────────────────────────────────────────────
# Development database (SQLite - auto-used when NODE_ENV != "production"):
DEV_DATABASE_URL="file:./vibesafe.db"

# Production database (PostgreSQL - auto-used when NODE_ENV = "production"):
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# ── Feature Flags ─────────────────────────────────────────────────────────────
# All features ENABLED by default. Disable specific features via JSON:
# FEATURES='{"stripe":false,"tierGating":false,"llmEnrichment":false}'
#
# Available features:
#  - performanceScanning  (Lighthouse performance analysis)
#  - accessibilityScanning (WCAG 2.2 compliance)
#  - seoScanning          (SEO optimization analysis)
#  - llmEnrichment        (AI-powered finding explanations)
#  - scanDiff             (Scan comparison)
#  - pdfExport            (PDF report generation)
#  - stripe               (Payment processing)
#  - auth                 (User authentication)
#  - tierGating           (Tier-based restrictions)
#  - desktopPerformance   (Desktop Lighthouse/PageSpeed pass — DEFAULT OFF; enabling doubles PageSpeed quota usage: one mobile + one desktop slot per scan)

# Example - disable monetization for open-source deployment:
# FEATURES='{"stripe":false,"tierGating":false}'

# ── PageSpeed Insights API ────────────────────────────────────────────────────
# Optional but recommended for performance/accessibility/SEO scanning
# Get free API key: https://console.cloud.google.com/apis/credentials
# Without key: Works but lower rate limits (25k requests/day shared)
# With key: Full quota + request tracking
PAGESPEED_API_KEY=""

# ── AI Enrichment (Optional) ──────────────────────────────────────────────────
# Claude API for AI-powered finding explanations
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ── Email (Transactional) ─────────────────────────────────────────────────────
# Used for sending verification emails on signup.
# Create a Gmail App Password: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on the Gmail account.)
GMAIL_USER="rahulsunny13@gmail.com"
GMAIL_APP_PASSWORD=""   # 16-char app password, no spaces

# ── Authentication ────────────────────────────────────────────────────────────
# Required if auth feature enabled
AUTH_PROVIDER="nextauth"  # or "supabase"

# NextAuth
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET=""  # Generate: openssl rand -base64 32

# GitHub OAuth: https://github.com/settings/developers
GITHUB_ID=""
GITHUB_SECRET=""

# Google OAuth: https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Supabase (if AUTH_PROVIDER="supabase")
# SUPABASE_URL=""
# SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""

# ── Payments ──────────────────────────────────────────────────────────────────
# Required if stripe feature enabled
# Get keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs (create in Stripe dashboard)
# Mapping after the May 2026 pricing pivot:
#   STRIPE_PRICE_ID_ONE_SHOT       = Verify ($9 one-time, 1 active DAST scan)
#   STRIPE_PRICE_ID_PRO_MONTHLY    = Active Pack ($29 one-time, 5 DAST scans) — note: now one-time, env name kept for migration
#   STRIPE_PRICE_ID_STUDIO_MONTHLY = Monitor ($15/mo subscription, per-domain)
STRIPE_PRICE_ID_ONE_SHOT=""
STRIPE_PRICE_ID_PRO_MONTHLY=""
STRIPE_PRICE_ID_STUDIO_MONTHLY=""

# Payment test bypass (DEV / STAGING ONLY)
# When true, clicking an Upgrade button grants the tier without charging.
# MUST be false in production. Hard-fails the checkout route if set in prod.
# Remove this flag (and the bypass branch in src/app/api/v1/checkout/route.ts)
# before GA — see "Pre-GA cleanup" in the plan.
PAYMENT_TEST_FLOW="false"

# ── Monitoring (Optional) ─────────────────────────────────────────────────────
# Sentry Error Tracking: https://sentry.io
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# Git SHA or deploy tag for release attribution (ties events to a specific build).
# Typically set in CI: SENTRY_RELEASE=$(git rev-parse --short HEAD)
# SENTRY_RELEASE=""
# Sentry auth token for source map upload during build (CI secret, minimal scope).
# Create at: https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/
# Required scope: project:releases — do NOT commit this value.
# SENTRY_AUTH_TOKEN=""

# ── Advanced Configuration ────────────────────────────────────────────────────
RATE_LIMIT_PER_HOUR="10"
SCAN_TIMEOUT_MS="120000"

# Redis (optional - for production job queue)
# REDIS_URL="redis://localhost:6379"

# Upstash Redis (optional — short-window rate limiting for /verify/check etc.)
# Without these, short-window limiters are a no-op (always allow).
# Free tier covers Phase 2 traffic; see https://console.upstash.com/.
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
