# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed for local dev):
DATABASE_URL="file:./vibesafe.db"
#
# PostgreSQL (production) — also change provider in prisma/schema.prisma:
# DATABASE_URL="postgresql://user:password@localhost:5432/vibesafe"

# ── Queue (optional) ──────────────────────────────────────────────────────────
# If unset, scan jobs run as a fire-and-forget Promise in the same process.
# This is fine for local dev. For production on Vercel, set this to run
# the worker on a separate Railway/Fly.io service.
# REDIS_URL="redis://localhost:6379"

# ── Frontend API ──────────────────────────────────────────────────────────────
# No longer needed — API routes live at the same origin (/api/v1/...).
# NEXT_PUBLIC_API_URL is deprecated.
