{
  "name": "vibesafe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/db-config.js development && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "postinstall": "node scripts/db-config.js && prisma generate",
    "db:config": "node scripts/db-config.js",
    "db:config:prod": "node scripts/db-config.js production",
    "db:migrate": "node scripts/db-config.js development && prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "node scripts/db-config.js development && prisma migrate reset",
    "db:push": "node scripts/db-config.js production && prisma db push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:fixtures": "vitest run src/__tests__/lib/scanner/fixtures",
    "test:corpus": "vitest run src/__tests__/lib/scanner/corpus",
    "corpus": "node scripts/corpus.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.709.0",
    "@aws-sdk/s3-request-presigner": "^3.709.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^8.45.1",
    "@types/nodemailer": "^8.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bullmq": "^5.76.6",
    "cheerio": "^1.2.0",
    "chrome-launcher": "^1.2.1",
    "fast-xml-parser": "^5.8.0",
    "lighthouse": "^12.8.2",
    "next": "14.2.29",
    "next-auth": "^4.24.11",
    "next-intl": "^3.26.5",
    "nodemailer": "^7.0.13",
    "playwright": "^1.59.1",
    "react": "^18",
    "react-dom": "^18",
    "redis": "^5.12.1",
    "robots-parser": "^3.0.1",
    "schema-dts": "^2.0.0",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.29",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "prettier": "^3",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "vitest-mock-extended": "^4.0.0"
  }
}
